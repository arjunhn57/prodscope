# Backend environment variables
# Copy to .env and fill in values

# Required: Claude API key for screen analysis + report generation
ANTHROPIC_API_KEY=sk-ant-...

# Required: Resend API key for emailing reports
RESEND_API_KEY=re_...

# Optional: Backend port (default: 8080)
PORT=8080

# Optional: Crawler version toggle
# true = new modular crawler (default)
# false = legacy random-tap crawl
USE_CRAWLER_V1=true
