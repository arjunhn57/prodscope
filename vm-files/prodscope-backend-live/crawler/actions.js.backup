/**
 * Action types the crawler understands.
 */
const ACTION_TYPES = {
  TAP: 'tap',
  TYPE: 'type',
  SCROLL_DOWN: 'scroll_down',
  SCROLL_UP: 'scroll_up',
  BACK: 'back',
};

/**
 * Parse bounds string "[x1,y1][x2,y2]" into {x1, y1, x2, y2, cx, cy}.
 */
function parseBounds(boundsStr) {
  const m = boundsStr.match(/\[(\d+),(\d+)\]\[(\d+),(\d+)\]/);
  if (!m) return null;
